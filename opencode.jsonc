{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "openkilo",
    "opencode-skill-creator",
    "./plugins/superpowers.js"
  ],
  "shell": "powershell",
  "mcp": {
    "infra-ops": {
      "type": "local",
      "command": ["infra-ops-mcp"],
      "enabled": true
    },
    "composio": {
      "type": "remote",
      "url": "https://connect.composio.dev/mcp",
      "enabled": true
    }
  }
}